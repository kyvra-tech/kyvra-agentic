# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# xAI API Key from console.x.ai
XAI_API_KEY=your_xai_api_key_here

# X (Twitter) API Bearer Token from developer.x.com → Projects & Apps → Keys
# Required for X - AI Leaders, X - AI Trending, X - Indie Dev sources
X_BEARER_TOKEN=your_x_bearer_token_here

# NewsAPI Key from newsapi.org (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Product Hunt API (optional, from api.producthunt.com)
PRODUCT_HUNT_API_KEY=

# Telegram chat IDs that receive scheduled daily reports (comma-separated)
# Example: 123456789,987654321
REPORT_CHAT_IDS=your_chat_id_here

# Daily report time (HH:MM, Vietnam time GMT+7)
REPORT_TIME=08:00

# Active module: tech | crypto
# tech  — AI/LLM/Indie Dev (Vietnamese audience)
# crypto — Bitcoin/DeFi/Web3 (English, CT-style)
ACTIVE_MODULE=tech

# Grok model to use
GROK_MODEL=grok-3-latest

# Ollama local fallback (used automatically when XAI_API_KEY is not set)
# Run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
