# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# Telegram bot token — create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat IDs that receive the daily auto-report (comma-separated)
# To find your chat ID: message @userinfobot on Telegram
REPORT_CHAT_IDS=your_chat_id_here

# ─────────────────────────────────────────────
# LLM PROVIDER — pick one
# ─────────────────────────────────────────────

# Option A: DeepSeek API (recommended — cheap, fast, no GPU needed)
# Get your free API key at https://platform.deepseek.com
CONTENT_LLM_PROVIDER=deepseek
CAPTION_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat



# ─────────────────────────────────────────────
# MODULE & SCHEDULE
# ─────────────────────────────────────────────

# Active news module
# Options: tech | crypto | vietnam | indie | parody | sport | political | war | humor | energy | markets
ACTIVE_MODULE=crypto

# Daily report time (HH:MM, 24h format)
REPORT_TIME=08:00

# Timezone for the scheduler
TIMEZONE=Asia/Ho_Chi_Minh

# ─────────────────────────────────────────────
# OPTIONAL — DATA SOURCES
# ─────────────────────────────────────────────

# Twitter/X API Bearer Token — improves crypto/tech signal quality
# Get at https://developer.x.com → Projects & Apps → Keys
X_BEARER_TOKEN=

# NewsAPI — additional news sources (free tier: 100 req/day)
# Get at https://newsapi.org
NEWS_API_KEY=

# Product Hunt API (optional)
PRODUCT_HUNT_API_KEY=

